# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Direct connection (migrations only - port 5432)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Pooled connection via Supavisor (application queries - port 6543)
# Use this for Drizzle ORM queries in production to leverage connection pooling.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_POOLED_URL=postgresql://postgres.your-project-ref:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Cron job authentication (generate: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here

# Public site URL used for auth email redirect links (password reset, magic link, etc.)
# In production set this to the deployed origin (例: https://step.example.com)
# このURLは Supabase Auth の "Site URL" / "Redirect URLs" にも登録すること
NEXT_PUBLIC_SITE_URL=http://localhost:3000
